{
  "manifest_version": 3,
  "name": "Fish Audio Automator",
  "version": "2.2.3",
  "description": "Automate Fish Audio TTS generation with bulk text file upload",
  "permissions": ["activeTab", "downloads", "storage", "sidePanel"],
  
  "host_permissions": [
    "https://fish.audio/*"
  ],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://fish.audio/*"],
      "js": ["content.js"]
    }
  ]
}